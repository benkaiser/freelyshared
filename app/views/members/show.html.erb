<% content_for :title, "#{@member.name} - FreelyShared" %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Members", members_path %></li>
      <li class="breadcrumb-item active"><%= @member.name %></li>
    </ol>
  </nav>

  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="text-center mb-4">
        <img src="<%= @member.gravatar_url(120) %>" class="rounded-circle mb-3" width="120" height="120" alt="">
        <h2><%= @member.name %></h2>
        <% if @member.phone.present? %>
          <p class="text-muted"><i class="bi bi-phone me-1"></i><%= @member.phone %></p>
        <% end %>
        <% if @member.show_email? %>
          <p class="text-muted"><i class="bi bi-envelope me-1"></i><%= @member.email %></p>
        <% end %>
      </div>

      <% if @items.any? %>
        <h4 class="mb-3">Items Available</h4>
        <div class="row g-3 mb-4">
          <% @items.each do |item| %>
            <div class="col-6 col-md-4">
              <%= link_to item, class: "text-decoration-none" do %>
                <div class="card listing-card h-100">
                  <% if item.photo.attached? %>
                    <%= image_tag item.photo_thumbnail, class: "card-img-top", style: "height: 120px; object-fit: cover;" %>
                  <% end %>
                  <div class="card-body p-2">
                    <h6 class="card-title mb-0 text-dark"><%= item.title %></h6>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @services.any? %>
        <h4 class="mb-3">Services Offered</h4>
        <% @services.each do |service| %>
          <%= link_to service_path(service), class: "text-decoration-none" do %>
            <div class="card listing-card mb-2">
              <div class="card-body p-3">
                <h6 class="text-dark mb-0"><%= service.title %></h6>
                <% if service.description.present? %>
                  <small class="text-muted"><%= truncate(service.description, length: 80) %></small>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
