<% content_for :title, "#{@service.title} - FreelyShared" %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Services", services_path %></li>
      <li class="breadcrumb-item active"><%= @service.title %></li>
    </ol>
  </nav>

  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <h2><%= @service.title %></h2>
            <% if @service.owner?(current_church_member) %>
              <div class="dropdown">
                <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="dropdown">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to "Edit", edit_service_path(@service), class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= button_to "Delete", service_path(@service), method: :delete, class: "dropdown-item text-danger", data: { turbo_confirm: "Are you sure?" } %></li>
                </ul>
              </div>
            <% end %>
          </div>

          <div class="d-flex align-items-center mb-3">
            <img src="<%= @service.church_member.gravatar_url(48) %>" class="rounded-circle me-3" width="48" height="48" alt="">
            <div>
              <strong><%= @service.church_member.name %></strong>
              <% if @service.church_member.phone.present? %>
                <br><small class="text-muted"><i class="bi bi-phone me-1"></i><%= @service.church_member.phone %></small>
              <% end %>
              <% if @service.church_member.show_email? %>
                <br><small class="text-muted"><i class="bi bi-envelope me-1"></i><%= @service.church_member.email %></small>
              <% end %>
            </div>
          </div>

          <% if @service.description.present? %>
            <div class="mb-3">
              <%= simple_format(@service.description) %>
            </div>
          <% end %>

          <% if @service.contact_preference.present? %>
            <div class="alert alert-info">
              <i class="bi bi-info-circle me-1"></i>
              <strong>Best way to reach me:</strong> <%= @service.contact_preference %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
