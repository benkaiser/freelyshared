<% content_for :title, "FreelyShared - Share Freely Within Your Church" %>

<!-- Hero Section -->
<section id="hero-search" class="hero hero-with-image bg-primary text-white py-5">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-3">Share Freely.<br>Love Generously.</h1>
        <p class="lead mb-4">
          Connect your church community through the joy of sharing.
          Lend what you have, borrow what you need — all within your church family.
        </p>

        <!-- Church Search -->
        <div
          class="position-relative mb-4"
          data-controller="church-search"
        >
          <div class="form-floating">
            <input
              type="text"
              class="form-control form-control-lg"
              id="church-input"
              placeholder="Search for your church..."
              data-church-search-target="input"
              data-action="input->church-search#search keydown->church-search#handleKeydown"
              autocomplete="off"
            >
            <label for="church-input" class="text-muted">
              <i class="bi bi-search me-2"></i>Find your church
            </label>
          </div>

          <!-- Search Results Dropdown -->
          <div
            class="dropdown-menu w-100 shadow-lg"
            data-church-search-target="dropdown"
            style="max-height: 400px; overflow-y: auto;"
          ></div>
        </div>

        <p class="text-white-50 mb-0">
          <small><i class="bi bi-info-circle"></i> Search for your church, or <a href="<%= new_church_path %>" class="text-white">register it</a> if you can't find it</small>
        </p>
      </div>

      <div class="col-lg-6 text-center">
        <div class="hero-illustration p-4">
          <i class="bi bi-people-fill text-white opacity-75" style="font-size: 8rem;"></i>
          <div class="mt-3">
            <i class="bi bi-arrow-left-right text-success" style="font-size: 2rem;"></i>
          </div>
          <div class="d-flex justify-content-center gap-4 mt-3">
            <i class="bi bi-tools text-white opacity-75" style="font-size: 3rem;"></i>
            <i class="bi bi-book text-white opacity-75" style="font-size: 3rem;"></i>
            <i class="bi bi-bicycle text-white opacity-75" style="font-size: 3rem;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section class="how-it-works py-5 bg-light">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center mb-5">
        <h2 class="h1 fw-bold text-dark">How FreelyShared Works</h2>
        <p class="lead text-muted">Sharing made simple for your church community</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-search" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">1. Find Your Church</h3>
          <p class="text-muted">
            Search for your church community. If it's not listed yet, register it and invite your members.
          </p>
        </div>
      </div>

      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-person-plus-fill" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">2. Gather Your People</h3>
          <p class="text-muted">
            Get 5 members signed up to activate your church's sharing community. The more the merrier!
          </p>
        </div>
      </div>

      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-info text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-gift" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">3. Share Freely</h3>
          <p class="text-muted">
            Once activated, list items to share, browse what's available, and borrow from your church family.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values Section -->
<section class="values py-5">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center mb-5">
        <h2 class="h1 fw-bold text-dark">Built on Biblical Values</h2>
        <p class="lead text-muted">Inspired by the early church's example of radical generosity</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-heart-fill text-danger me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Generosity</h3>
          </div>
          <p class="text-muted mb-3">
            Share freely with your brothers and sisters. When you lend, you reflect the generous heart of God
            and strengthen your church community.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Give, and it will be given to you" — Luke 6:38
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-people-fill text-primary me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Fellowship</h3>
          </div>
          <p class="text-muted mb-3">
            Sharing creates connection. Every exchange is an opportunity to deepen relationships
            and practice the "one another" commands of Scripture.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Carry each other's burdens" — Galatians 6:2
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-hand-thumbs-up-fill text-success me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Stewardship</h3>
          </div>
          <p class="text-muted mb-3">
            Be good stewards of what God has given. Sharing maximizes the usefulness of every
            resource and reduces waste in our communities.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Each of you should use whatever gift you have received to serve others" — 1 Peter 4:10
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Call to Action Section -->
<section class="cta py-5 bg-primary text-white">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <h2 class="h1 fw-bold mb-4">Ready to Share Freely?</h2>
        <p class="lead mb-4">
          Join churches across the country who are rediscovering the joy of generous sharing.
          Find your church or register it today.
        </p>

        <div class="d-flex justify-content-center gap-3">
          <button
            class="btn btn-success btn-lg"
            onclick="document.getElementById('church-input').scrollIntoView({behavior: 'smooth'}); setTimeout(() => document.getElementById('church-input').focus(), 500);"
          >
            <i class="bi bi-search"></i> Find Your Church
          </button>
          <a href="<%= new_church_path %>" class="btn btn-outline-light btn-lg">
            <i class="bi bi-plus-circle"></i> Register Your Church
          </a>
        </div>

        <!-- Acts 4:32 Quote -->
        <div class="mt-5 p-4 bg-white bg-opacity-10 rounded">
          <p class="mb-0">
            <i class="bi bi-quote" style="font-size: 1.5rem;"></i>
            <em class="fs-5">
              "All the believers were one in heart and mind. No one claimed that any of their possessions
              was their own, but they shared everything they had."
            </em>
            <br>
            <strong class="text-white-75 mt-2 d-inline-block">— Acts 4:32</strong>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .min-vh-75 {
    min-height: 75vh;
  }

  .hero-illustration {
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .step-card, .value-card, .feature-card {
    transition: transform 0.3s ease;
  }

  .step-card:hover, .value-card:hover, .feature-card:hover {
    transform: translateY(-5px);
  }

  .text-white-75 {
    color: rgba(255, 255, 255, 0.75) !important;
  }
</style>
