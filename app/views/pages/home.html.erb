<% content_for :title, "FreelyShared - Share Freely Within Your Church" %>
<% content_for :og_description, "Join your church's sharing community. Lend tools, borrow a tent, offer your skills, or ask for help — all within your church family. Built on the biblical value of generous sharing." %>

<!-- Hero Section -->
<section id="hero-search" class="hero hero-with-image bg-primary text-white py-5">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-3">Share Freely.<br>Love Generously.</h1>
        <p class="lead mb-4">
          Connect your church community through the joy of sharing.
          Lend what you have, borrow what you need, and offer your skills to serve — all within your church family.
        </p>

        <!-- Church Search -->
        <div
          class="position-relative mb-4"
          data-controller="church-search"
        >
          <div class="form-floating">
            <input
              type="text"
              class="form-control form-control-lg"
              id="church-input"
              placeholder="Search for your church..."
              data-church-search-target="input"
              data-action="input->church-search#search keydown->church-search#handleKeydown"
              autocomplete="off"
            >
            <label for="church-input" class="text-muted">
              <i class="bi bi-search me-2"></i>Find your church
            </label>
          </div>

          <!-- Search Results Dropdown -->
          <div
            class="dropdown-menu w-100 shadow-lg"
            data-church-search-target="dropdown"
            style="max-height: 400px; overflow-y: auto;"
          ></div>
        </div>

        <p class="text-white-50 mb-0">
          <small><i class="bi bi-info-circle"></i> Search for your church, or <a href="<%= new_church_path %>" class="text-white">register it</a> if you can't find it</small>
        </p>
      </div>

      <div class="col-lg-6 d-none d-lg-block">
        <% if @showcase_items.present? && @showcase_items.any? { |i| i.photo.attached? } %>
          <div class="hero-photo-collage">
            <% @showcase_items.select { |i| i.photo.attached? }.first(4).each_with_index do |item, idx| %>
              <div class="hero-photo-item hero-photo-<%= idx + 1 %>">
                <%= image_tag item.photo_thumbnail, alt: item.title %>
                <span class="hero-photo-label"><%= item.title %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="hero-illustration p-4 text-center">
            <i class="bi bi-people-fill text-white opacity-75" style="font-size: 8rem;"></i>
            <div class="mt-3">
              <i class="bi bi-arrow-left-right text-success" style="font-size: 2rem;"></i>
            </div>
            <div class="d-flex justify-content-center gap-4 mt-3">
              <i class="bi bi-tools text-white opacity-75" style="font-size: 3rem;"></i>
              <i class="bi bi-book text-white opacity-75" style="font-size: 3rem;"></i>
              <i class="bi bi-wrench text-white opacity-75" style="font-size: 3rem;"></i>
              <i class="bi bi-heart text-white opacity-75" style="font-size: 3rem;"></i>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- "See It In Action" Showcase Section -->
<% if @showcase_church && @showcase_items.present? %>
<section class="showcase py-5">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="h1 fw-bold text-dark">See What Sharing Looks Like</h2>
      <p class="lead text-muted">A peek inside <strong><%= @showcase_church.name %></strong>'s sharing community</p>
    </div>

    <!-- Showcase Items -->
    <h5 class="text-muted mb-3"><i class="bi bi-box-seam me-2"></i>Items Available to Borrow</h5>
    <div class="showcase-scroll mb-4">
      <% @showcase_items.each do |item| %>
        <div class="showcase-card">
          <div class="showcase-card-img">
            <% if item.photo.attached? %>
              <%= image_tag item.photo_thumbnail, alt: item.title %>
            <% else %>
              <div class="showcase-card-placeholder">
                <i class="bi bi-image text-muted"></i>
              </div>
            <% end %>
          </div>
          <div class="showcase-card-body">
            <h6 class="showcase-card-title"><%= item.title %></h6>
            <div class="d-flex align-items-center justify-content-between">
              <span class="badge bg-light text-dark category-badge"><%= item.category %></span>
              <div class="d-flex align-items-center">
                <img src="<%= item.church_member.avatar_url(24) %>" class="rounded-circle" width="24" height="24" alt="<%= item.church_member.name %>">
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="row g-3">
      <!-- Showcase Services -->
      <% if @showcase_services.present? %>
        <div class="<%= @showcase_needs.present? ? 'col-md-6' : 'col-12' %>">
          <h5 class="text-muted mb-3"><i class="bi bi-hand-thumbs-up me-2"></i>Skills & Services Offered</h5>
          <% @showcase_services.each do |service| %>
            <div class="showcase-mini-card mb-2">
              <div class="d-flex align-items-center">
                <img src="<%= service.church_member.avatar_url(36) %>" class="rounded-circle me-3" width="36" height="36" alt="<%= service.church_member.name %>">
                <div>
                  <strong class="text-dark"><%= service.title %></strong>
                  <div class="text-muted small"><%= service.church_member.name %></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Showcase Needs -->
      <% if @showcase_needs.present? %>
        <div class="<%= @showcase_services.present? ? 'col-md-6' : 'col-12' %>">
          <h5 class="text-muted mb-3"><i class="bi bi-megaphone me-2"></i>Community Needs</h5>
          <% @showcase_needs.each do |need| %>
            <div class="showcase-mini-card mb-2">
              <div class="d-flex align-items-center">
                <img src="<%= need.church_member.avatar_url(36) %>" class="rounded-circle me-3" width="36" height="36" alt="<%= need.church_member.name %>">
                <div>
                  <strong class="text-dark"><%= need.title %></strong>
                  <div class="text-muted small">Posted by <%= need.church_member.name %></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- How It Works Section -->
<section class="how-it-works py-5 bg-light">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center mb-5">
        <h2 class="h1 fw-bold text-dark">How FreelyShared Works</h2>
        <p class="lead text-muted">Sharing made simple for your church community</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-search" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">1. Find Your Church</h3>
          <p class="text-muted">
            Search for your church community. If it's not listed yet, register it and invite your members.
          </p>
        </div>
      </div>

      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-person-plus-fill" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">2. Gather Your People</h3>
          <p class="text-muted">
            Get 5 members signed up to activate your church's sharing community. The more the merrier!
          </p>
          <% if @showcase_members.present? %>
            <div class="avatar-cluster mt-2">
              <% @showcase_members.first(5).each do |member| %>
                <img src="<%= member.avatar_url(40) %>" class="avatar-cluster-img" alt="<%= member.name %>" title="<%= member.name %>" width="40" height="40">
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-md-4 text-center">
        <div class="step-card h-100">
          <div class="step-icon mb-3">
            <div class="rounded-circle bg-info text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
              <i class="bi bi-gift" style="font-size: 2rem;"></i>
            </div>
          </div>
          <h3 class="h4 fw-bold">3. Share Freely</h3>
          <p class="text-muted">
            Share goods, offer your skills, and serve your church family — from lending tools to helping someone move.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values Section -->
<section class="values py-5">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center mb-5">
        <h2 class="h1 fw-bold text-dark">Built on Biblical Values</h2>
        <p class="lead text-muted">Inspired by the early church's example of radical generosity</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-heart-fill text-danger me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Generosity</h3>
          </div>
          <p class="text-muted mb-3">
            Share freely with your brothers and sisters — whether it's lending a tool or offering your time and skills.
            When you give, you reflect the generous heart of God and strengthen your church community.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Give, and it will be given to you" — Luke 6:38
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-people-fill text-primary me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Fellowship</h3>
          </div>
          <p class="text-muted mb-3">
            Sharing creates connection. Every item lent and every act of service is an opportunity to deepen relationships
            and practice the "one another" commands of Scripture.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Carry each other's burdens" — Galatians 6:2
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="value-card h-100">
          <div class="d-flex align-items-center mb-3">
            <i class="bi bi-hand-thumbs-up-fill text-success me-3" style="font-size: 2rem;"></i>
            <h3 class="h4 fw-bold mb-0">Stewardship</h3>
          </div>
          <p class="text-muted mb-3">
            Be good stewards of what God has given — your possessions, your skills, and your time.
            Sharing maximizes the usefulness of every resource and every gift in our communities.
          </p>
          <div class="small text-muted">
            <i class="bi bi-book"></i> "Each of you should use whatever gift you have received to serve others" — 1 Peter 4:10
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Call to Action Section -->
<section class="cta py-5 bg-primary text-white">
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8">
        <h2 class="h1 fw-bold mb-4">Ready to Share Freely?</h2>
        <p class="lead mb-4">
          Join churches across the country who are rediscovering the joy of generous sharing —
          goods, skills, and time freely given to serve one another. Find your church or register it today.
        </p>

        <div class="d-flex justify-content-center gap-3">
          <button
            class="btn btn-success btn-lg"
            onclick="document.getElementById('church-input').scrollIntoView({behavior: 'smooth'}); setTimeout(() => document.getElementById('church-input').focus(), 500);"
          >
            <i class="bi bi-search"></i> Find Your Church
          </button>
          <a href="<%= new_church_path %>" class="btn btn-outline-light btn-lg">
            <i class="bi bi-plus-circle"></i> Register Your Church
          </a>
        </div>

        <!-- Acts 4:32 Quote -->
        <div class="mt-5 p-4 bg-white bg-opacity-10 rounded">
          <p class="mb-0">
            <i class="bi bi-quote" style="font-size: 1.5rem;"></i>
            <em class="fs-5">
              "All the believers were one in heart and mind. No one claimed that any of their possessions
              was their own, but they shared everything they had."
            </em>
            <br>
            <strong class="text-white-75 mt-2 d-inline-block">— Acts 4:32</strong>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .min-vh-75 {
    min-height: 75vh;
  }

  .hero-illustration {
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .step-card, .value-card, .feature-card {
    transition: transform 0.3s ease;
  }

  .step-card:hover, .value-card:hover, .feature-card:hover {
    transform: translateY(-5px);
  }

  .text-white-75 {
    color: rgba(255, 255, 255, 0.75) !important;
  }
</style>
