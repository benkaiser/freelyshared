<% content_for :title, "My Churches - FreelyShared" %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h2 class="mb-4">
        <i class="bi bi-building text-primary me-2"></i>My Churches
      </h2>

      <!-- Approved Memberships -->
      <% if @approved_memberships.any? %>
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-check-circle me-2"></i>Active Memberships</h5>
          </div>
          <div class="card-body">
            <div class="list-group list-group-flush">
              <% @approved_memberships.each do |membership| %>
                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                  <div>
                    <strong><%= membership.church.name %></strong>
                    <br><small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= membership.church.location_name %></small>
                    <% if membership.admin? %>
                      <span class="badge bg-primary ms-1">Admin</span>
                    <% end %>
                    <% if membership.church_id == current_church&.id %>
                      <span class="badge bg-info ms-1">Current</span>
                    <% end %>
                  </div>
                  <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-outline-secondary btn-sm" type="button"
                            onclick="navigator.clipboard.writeText('<%= "#{app_url}/churches/#{membership.church_id}" %>'); this.innerHTML='<i class=\'bi bi-check-lg\'></i>'; setTimeout(() => this.innerHTML='<i class=\'bi bi-share\'></i>', 2000)"
                            title="Copy sign-up link">
                      <i class="bi bi-share"></i>
                    </button>
                    <% unless membership.church_id == current_church&.id %>
                      <%= button_to "Switch", switch_church_path(church_id: membership.church_id), method: :post, class: "btn btn-outline-primary btn-sm" %>
                    <% end %>
                    <%= button_to church_membership_path(membership), method: :delete,
                          class: "btn btn-outline-danger btn-sm",
                          data: { turbo_confirm: "Are you sure you want to leave #{membership.church.name}?" } do %>
                      <i class="bi bi-box-arrow-right me-1"></i>Leave
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Pending Memberships -->
      <% if @pending_memberships.any? %>
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Pending Requests</h5>
          </div>
          <div class="card-body">
            <div class="list-group list-group-flush">
              <% @pending_memberships.each do |membership| %>
                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                  <div>
                    <strong><%= membership.church.name %></strong>
                    <br><small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= membership.church.location_name %></small>
                    <br><small class="text-muted">Requested <%= time_ago_in_words(membership.created_at) %> ago</small>
                  </div>
                  <%= button_to church_membership_path(membership), method: :delete,
                        class: "btn btn-outline-secondary btn-sm",
                        data: { turbo_confirm: "Cancel your request to join #{membership.church.name}?" } do %>
                    <i class="bi bi-x-lg me-1"></i>Cancel
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Join Another Church -->
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Join Another Church</h5>
        </div>
        <div class="card-body">
          <p class="text-muted">Search for a church to join:</p>
          <div class="input-group mb-3">
            <input type="text" id="church-search-input" class="form-control" placeholder="Search by church name..." autocomplete="off">
          </div>
          <div id="church-search-results"></div>
        </div>
      </div>

      <div class="text-center mt-4">
        <%= link_to profile_path, class: "btn btn-outline-secondary" do %>
          <i class="bi bi-arrow-left me-1"></i> Back to Profile
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const input = document.getElementById("church-search-input");
    const results = document.getElementById("church-search-results");
    let timeout;

    if (!input) return;

    input.addEventListener("input", function() {
      clearTimeout(timeout);
      const q = input.value.trim();
      if (q.length < 2) { results.innerHTML = ""; return; }

      timeout = setTimeout(function() {
        fetch("/churches/search?q=" + encodeURIComponent(q))
          .then(r => r.json())
          .then(churches => {
            if (churches.length === 0) {
              results.innerHTML = '<p class="text-muted">No churches found.</p>';
              return;
            }
            let html = '<div class="list-group">';
            churches.forEach(c => {
              html += `<a href="/churches/${c.id}" class="list-group-item list-group-item-action">
                <strong>${c.name}</strong>
                <br><small class="text-muted">${c.location_name} &middot; ${c.member_count} members</small>
              </a>`;
            });
            html += '</div>';
            results.innerHTML = html;
          });
      }, 300);
    });
  });
</script>
