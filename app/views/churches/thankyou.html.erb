<% content_for :title, "Thank you! - FreelyShared" %>

<div class="container my-5">
  <div class="row">
    <div class="col-lg-6 mx-auto text-center">
      <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
      </div>

      <h1 class="display-4 mb-3">Thank you!</h1>

      <p class="lead mb-4">
        <% if @church.status == "ready" %>
          <strong><%= @church.name %></strong> is now active with <%= @church.member_count %> members!
          You'll receive an email when the sharing platform is ready.
        <% else %>
          You've joined <strong><%= @church.name %></strong>.
          <br>
          <span class="text-muted">
            <%= @church.members_needed %> more member<%= @church.members_needed == 1 ? "" : "s" %> needed to activate your community.
          </span>
        <% end %>
      </p>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title">
            <i class="bi bi-people-fill text-primary me-2"></i>
            Help grow your church community
          </h5>
          <p class="card-text text-muted">
            Share this link with your church family so they can join too!
          </p>

          <div class="d-grid gap-2 d-md-flex justify-content-md-center">
            <button
              class="btn btn-primary"
              data-controller="share-button"
              data-action="click->share-button#share"
              data-share-button-url-value="<%= church_url(@church) %>"
              data-share-button-title-value="Join <%= @church.name %> on FreelyShared"
              data-share-button-text-value="Join our church's sharing community on FreelyShared! Share goods, offer skills, and serve one another."
            >
              <i class="bi bi-share-fill me-2"></i>Share with church family
            </button>

            <button
              class="btn btn-outline-secondary"
              data-controller="copy-button"
              data-action="click->copy-button#copy"
              data-copy-button-text-value="<%= church_url(@church) %>"
            >
              <i class="bi bi-clipboard me-2"></i>Copy link
            </button>
          </div>
        </div>
      </div>

      <% if @church.status == "pending" %>
        <div class="alert alert-info">
          <i class="bi bi-hourglass-split me-2"></i>
          <strong>Almost there!</strong> Your church needs <%= @church.members_needed %> more member<%= @church.members_needed == 1 ? "" : "s" %> to activate.
          Everyone will be notified by email once the community is ready!
        </div>
      <% end %>

      <div class="mt-4">
        <a href="<%= root_path %>" class="btn btn-outline-primary">
          <i class="bi bi-house-fill me-2"></i>Back to home
        </a>
      </div>
    </div>
  </div>
</div>
