<% content_for :title, "Request Submitted - FreelyShared" %>

<section class="py-5">
  <div class="container">
    <div class="row">
      <div class="col-lg-6 mx-auto text-center">
        <div class="card shadow-sm">
          <div class="card-body p-5">
            <div class="mb-4">
              <i class="bi bi-hourglass-split text-warning" style="font-size: 4rem;"></i>
            </div>
            <h2 class="mb-3">Request Submitted</h2>
            <p class="text-muted mb-4">
              Your request to join <strong><%= @church.name %></strong> has been submitted.
              A church admin will review your request and you'll receive an email once approved.
            </p>
            <div class="bg-light rounded p-3">
              <p class="text-muted small mb-0">
                <i class="bi bi-envelope me-1"></i>
                Check your email for updates. In the meantime, feel free to reach out to your church leaders.
              </p>
            </div>
            <div class="mt-4">
              <%= link_to root_path, class: "btn btn-outline-primary" do %>
                <i class="bi bi-house me-1"></i> Back to Home
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
