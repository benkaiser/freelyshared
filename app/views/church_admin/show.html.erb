<% content_for :title, "Church Admin - FreelyShared" %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h2 class="mb-4">
        <i class="bi bi-shield-check text-primary me-2"></i>Church Admin
      </h2>

      <!-- Church Settings -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Church Settings</h5>
        </div>
        <div class="card-body">
          <%= form_with url: update_settings_church_admin_path, method: :patch, local: true do %>
            <div class="mb-3">
              <label for="church_name" class="form-label"><strong>Church Name</strong></label>
              <input type="text" name="church_name" id="church_name" class="form-control" value="<%= @church.name %>" required>
            </div>
            <%= render "shared/location_autocomplete", church: @church %>
            <div class="form-check form-switch">
              <input type="hidden" name="require_admin_approval" value="0">
              <input type="checkbox" name="require_admin_approval" value="1"
                     class="form-check-input" id="require_admin_approval"
                     <%= "checked" if @church.require_admin_approval? %>>
              <label class="form-check-label" for="require_admin_approval">
                <strong>Require admin approval for new members</strong>
              </label>
            </div>
            <small class="text-muted d-block mt-1 mb-3">
              When enabled, new members must be approved by an admin before they can access the church community.
            </small>
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-check me-1"></i>Save Settings
            </button>
          <% end %>
        </div>
      </div>

      <!-- Pending Members -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-dark">
          <h5 class="mb-0">
            <i class="bi bi-hourglass-split me-2"></i>Pending Requests
            <% if @pending_memberships.any? %>
              <span class="badge bg-danger ms-2"><%= @pending_memberships.count %></span>
            <% end %>
          </h5>
        </div>
        <div class="card-body">
          <% if @pending_memberships.any? %>
            <div class="list-group list-group-flush">
              <% @pending_memberships.each do |membership| %>
                <% member = membership.church_member %>
                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                  <div>
                    <div class="d-flex align-items-center">
                      <img src="<%= member.avatar_url(32) %>" class="rounded-circle me-2" width="32" height="32" alt="">
                      <div>
                        <strong><%= member.name %></strong>
                        <br><small class="text-muted"><%= member.email %></small>
                        <br><small class="text-muted">Requested <%= time_ago_in_words(membership.created_at) %> ago</small>
                      </div>
                    </div>
                  </div>
                  <div class="d-flex gap-2">
                    <%= button_to approve_member_church_admin_path(member_id: member.id),
                          method: :post, class: "btn btn-success btn-sm" do %>
                      <i class="bi bi-check-lg me-1"></i>Approve
                    <% end %>
                    <%= button_to reject_member_church_admin_path(member_id: member.id),
                          method: :post, class: "btn btn-outline-danger btn-sm",
                          data: { turbo_confirm: "Are you sure you want to reject #{member.name}?" } do %>
                      <i class="bi bi-x-lg me-1"></i>Reject
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">
              <i class="bi bi-check-circle text-success me-1"></i>No pending requests.
            </p>
          <% end %>
        </div>
      </div>

      <!-- All Members -->
      <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="bi bi-people me-2"></i>Members (<%= @approved_memberships.count %>)</h5>
        </div>
        <div class="card-body">
          <div class="list-group list-group-flush">
            <% @approved_memberships.each do |membership| %>
              <% member = membership.church_member %>
              <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                <div class="d-flex align-items-center">
                  <img src="<%= member.avatar_url(32) %>" class="rounded-circle me-2" width="32" height="32" alt="">
                  <div>
                    <strong><%= member.name %></strong>
                    <% if membership.admin? %>
                      <span class="badge bg-primary ms-1">Admin</span>
                    <% end %>
                    <br><small class="text-muted"><%= member.email %></small>
                  </div>
                </div>
                <div>
                  <% if member == current_church_member %>
                    <span class="badge bg-secondary">You</span>
                  <% else %>
                    <%= button_to toggle_admin_church_admin_path(member_id: member.id),
                          method: :post, class: "btn btn-outline-primary btn-sm" do %>
                      <% if membership.admin? %>
                        <i class="bi bi-shield-x me-1"></i>Remove Admin
                      <% else %>
                        <i class="bi bi-shield-plus me-1"></i>Make Admin
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
