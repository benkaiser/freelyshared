<% content_for :title, "Reset Password - FreelyShared" %>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="text-center mb-4">
          <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
          <h2 class="mt-2">Change Your Password</h2>
        </div>

        <div class="card shadow-sm">
          <div class="card-body p-4">
            <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "row g-3" }) do |f| %>
              <%= render "church_members/shared/error_messages", resource: resource %>
              <%= f.hidden_field :reset_password_token %>

              <div class="col-12">
                <%= f.label :password, "New password", class: "form-label fw-semibold" %>
                <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control form-control-lg" %>
                <% if @minimum_password_length %>
                  <small class="text-muted"><%= @minimum_password_length %> characters minimum</small>
                <% end %>
              </div>

              <div class="col-12">
                <%= f.label :password_confirmation, "Confirm new password", class: "form-label fw-semibold" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
              </div>

              <div class="col-12">
                <%= f.submit "Change my password", class: "btn btn-primary btn-lg w-100" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
