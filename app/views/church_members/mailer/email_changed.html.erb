<p>Hi <%= @email %>,</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p>We're letting you know that your email is being changed to <strong><%= @resource.unconfirmed_email %></strong>.</p>
<% else %>
  <p>We're letting you know that your email has been changed to <strong><%= @resource.email %></strong>.</p>
<% end %>

<p>If you did not make this change, please contact us immediately.</p>
