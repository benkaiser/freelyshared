<p>Hi <%= @resource.name.presence || @resource.email %>,</p>

<p>Your account has been locked due to too many unsuccessful sign-in attempts.</p>

<p>Click the button below to unlock your account:</p>

<p style="text-align: center;">
  <%= link_to 'Unlock My Account', unlock_url(@resource, unlock_token: @token), class: 'btn' %>
</p>
