<% content_for :title, "Needs Board - FreelyShared" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-hand-thumbs-up text-primary me-2"></i>Needs Board</h2>
    <%= link_to new_need_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i> Post a Need
    <% end %>
  </div>

  <% if @needs.any? %>
    <div class="row g-3">
      <% @needs.each do |need| %>
        <div class="col-md-6 col-lg-4">
          <%= link_to need, class: "text-decoration-none" do %>
            <div class="card listing-card h-100">
              <div class="card-body">
                <h5 class="card-title text-dark"><%= need.title %></h5>
                <% if need.description.present? %>
                  <p class="card-text text-muted small"><%= truncate(need.description, length: 120) %></p>
                <% end %>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                  <div class="d-flex align-items-center">
                    <img src="<%= need.church_member.gravatar_url(24) %>" class="rounded-circle me-1" width="24" height="24" alt="">
                    <small class="text-muted"><%= need.church_member.name %></small>
                  </div>
                  <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>expires <%= distance_of_time_in_words_to_now(need.expires_at) %>
                  </small>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <i class="bi bi-hand-thumbs-up d-block"></i>
      <h4 class="text-muted">No open needs</h4>
      <p class="text-muted">Post a need and let your church community help!</p>
      <%= link_to new_need_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i> Post Your First Need
      <% end %>
    </div>
  <% end %>
</div>
