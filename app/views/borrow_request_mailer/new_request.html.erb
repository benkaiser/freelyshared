<p>Hi <%= @owner.name %>,</p>

<p><strong><%= @requester.name %></strong> would like to borrow your <strong><%= @item.title %></strong>.</p>

<div style="margin: 10px 0; padding: 10px; background: #f8f9fa; border-radius: 8px;">
  <strong>Dates:</strong> <%= @borrow_request.start_date.strftime("%B %d, %Y") %> - <%= @borrow_request.end_date.strftime("%B %d, %Y") %>
</div>

<% if @borrow_request.phone.present? %>
  <div style="margin: 10px 0; padding: 10px; background: #f8f9fa; border-radius: 8px;">
    <strong>Contact:</strong> <%= @borrow_request.phone %>
  </div>
<% end %>

<p style="text-align: center;">
  <a href="<%= item_url(@item) %>" class="btn">View Request & Confirm</a>
</p>
