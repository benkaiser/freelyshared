<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FreelyShared" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0d6efd">

    <% og_title = content_for(:title).presence || "FreelyShared - Share Freely Within Your Church" %>
    <% og_description = content_for(:og_description).presence || "Connect your church community through sharing. Lend what you have, borrow what you need, and offer your skills to serve — all within your church family." %>
    <% og_image = content_for(:og_image).presence || "#{request.base_url}/og-image.png" %>

    <meta name="description" content="<%= og_description %>">
    <meta property="og:title" content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:image" content="<%= og_image %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="FreelyShared">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
    <meta name="twitter:image" content="<%= og_image %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <!-- Impersonation Banner -->
    <% if session[:superadmin_id].present? %>
      <div class="bg-warning text-dark text-center py-2 fw-bold">
        <i class="bi bi-exclamation-triangle me-1"></i>
        You are impersonating <%= current_church_member&.name %>
        &mdash;
        <%= button_to "Stop Impersonating", superadmin_stop_impersonating_path, method: :post, class: "btn btn-sm btn-dark ms-2" %>
      </div>
    <% end %>

    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
      <div class="container">
        <%= link_to (church_member_signed_in? ? dashboard_path : root_path), class: "navbar-brand d-flex align-items-center text-decoration-none" do %>
          <div class="brand-icon me-2">
            <i class="bi bi-people-fill text-primary" style="font-size: 1.5rem;"></i>
          </div>
          <span class="fw-bold text-primary fs-4">FreelyShared</span>
        <% end %>

        <% if church_member_signed_in? %>
          <% user_churches = current_church_member.approved_churches %>
          <% if user_churches.count > 1 %>
            <div class="dropdown d-none d-lg-inline me-3">
              <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-building me-1"></i><%= current_church&.name %>
              </button>
              <ul class="dropdown-menu">
                <% user_churches.each do |church| %>
                  <li>
                    <% if church.id == current_church&.id %>
                      <span class="dropdown-item active"><i class="bi bi-check-lg me-1"></i><%= church.name %></span>
                    <% else %>
                      <%= button_to switch_church_path(church_id: church.id), method: :post, class: "dropdown-item" do %>
                        <%= church.name %>
                      <% end %>
                    <% end %>
                  </li>
                <% end %>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Manage Churches", church_memberships_path, class: "dropdown-item" %></li>
              </ul>
            </div>
          <% else %>
            <span class="text-muted d-none d-lg-inline me-3">
              <i class="bi bi-building me-1"></i><%= current_church&.name %>
            </span>
          <% end %>
        <% end %>

        <div class="navbar-nav ms-auto">
          <% if church_member_signed_in? %>
            <!-- Desktop navigation links -->
            <div class="d-none d-lg-flex align-items-center">
              <% if current_church&.status == "ready" %>
                <%= link_to items_path, class: "nav-link #{'active' if controller_name == 'items' && action_name == 'index'}" do %>
                  <i class="bi bi-box-seam me-1"></i> Browse Items
                <% end %>
                <%= link_to services_path, class: "nav-link #{'active' if controller_name == 'services_listings'}" do %>
                  <i class="bi bi-tools me-1"></i> Services
                <% end %>
                <%= link_to needs_path, class: "nav-link #{'active' if controller_name == 'needs'}" do %>
                  <i class="bi bi-hand-thumbs-up me-1"></i> Needs
                <% end %>
                <%= link_to my_listings_path, class: "nav-link #{'active' if request.path == my_listings_path}" do %>
                  <i class="bi bi-list-ul me-1"></i> My Listings
                <% end %>
              <% end %>
              <%= link_to profile_path, class: "nav-link #{'active' if controller_name == 'profiles'}" do %>
                <i class="bi bi-person me-1"></i> Profile
                <% if pending_borrow_requests_count > 0 %>
                  <span class="badge bg-danger rounded-pill"><%= pending_borrow_requests_count %></span>
                <% end %>
              <% end %>
              <% if current_church_member&.admin_of?(current_church) %>
                <% pending_count = current_church.church_memberships.pending_approval.count %>
                <%= link_to church_admin_path, class: "nav-link #{'active' if controller_name == 'church_admin'}" do %>
                  <i class="bi bi-shield-check me-1"></i> Admin
                  <% if pending_count > 0 %>
                    <span class="badge bg-danger rounded-pill"><%= pending_count %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
            <%= link_to destroy_church_member_session_path, data: { turbo_method: :delete }, class: "nav-link text-muted ms-2" do %>
              <i class="bi bi-box-arrow-right"></i> Sign out
            <% end %>
          <% else %>
            <%= link_to new_church_member_session_path, class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-box-arrow-in-right me-1"></i> Sign in
            <% end %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Church name bar on mobile -->
    <% if church_member_signed_in? %>
      <% user_churches = current_church_member.approved_churches %>
      <% if user_churches.count > 1 %>
        <div class="d-lg-none bg-light border-bottom py-1 text-center">
          <div class="dropdown">
            <button class="btn btn-link btn-sm text-muted text-decoration-none dropdown-toggle p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-building me-1"></i><%= current_church&.name %>
            </button>
            <ul class="dropdown-menu">
              <% user_churches.each do |church| %>
                <li>
                  <% if church.id == current_church&.id %>
                    <span class="dropdown-item active"><i class="bi bi-check-lg me-1"></i><%= church.name %></span>
                  <% else %>
                    <%= button_to switch_church_path(church_id: church.id), method: :post, class: "dropdown-item" do %>
                      <%= church.name %>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "Manage Churches", church_memberships_path, class: "dropdown-item" %></li>
            </ul>
          </div>
        </div>
      <% else %>
        <div class="d-lg-none bg-light border-bottom py-1 text-center">
          <small class="text-muted">
            <i class="bi bi-building me-1"></i><%= current_church&.name %>
          </small>
        </div>
      <% end %>
    <% end %>

    <!-- Main Content -->
    <main class="flex-grow-1 pb-5 pb-lg-0">
      <% if flash[:alert] %>
        <div class="container mt-3">
          <div class="alert alert-danger alert-dismissible fade show">
            <%= flash[:alert] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>
      <% end %>
      <% if flash[:notice] %>
        <div class="container mt-3">
          <div class="alert alert-success alert-dismissible fade show">
            <%= flash[:notice] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <!-- Bottom Tab Navigation (mobile only, authenticated only) -->
    <% if church_member_signed_in? && current_church&.status == "ready" %>
      <nav class="d-lg-none fixed-bottom bg-white border-top shadow-lg bottom-nav">
        <div class="d-flex justify-content-around py-1">
          <%= link_to items_path, class: "bottom-nav-item #{'active' if controller_name == 'items' && action_name == 'index'}" do %>
            <i class="bi bi-box-seam"></i>
            <span>Items</span>
          <% end %>
          <%= link_to services_path, class: "bottom-nav-item #{'active' if controller_name == 'services_listings'}" do %>
            <i class="bi bi-tools"></i>
            <span>Services</span>
          <% end %>
          <%= link_to needs_path, class: "bottom-nav-item #{'active' if controller_name == 'needs'}" do %>
            <i class="bi bi-hand-thumbs-up"></i>
            <span>Needs</span>
          <% end %>
          <%= link_to my_listings_path, class: "bottom-nav-item #{'active' if request.path == my_listings_path}" do %>
            <i class="bi bi-list-ul"></i>
            <span>My Listings</span>
          <% end %>
          <%= link_to profile_path, class: "bottom-nav-item #{'active' if controller_name == 'profiles'}" do %>
            <span class="position-relative">
              <i class="bi bi-person"></i>
              <% if pending_borrow_requests_count > 0 %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                  <%= pending_borrow_requests_count %>
                </span>
              <% end %>
            </span>
            <span>Profile</span>
          <% end %>
        </div>
      </nav>
    <% end %>

    <!-- Footer (hidden on mobile when nav is shown) -->
    <footer class="bg-light py-4 mt-auto <%= 'd-none d-lg-block' if church_member_signed_in? %>">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-people-fill text-primary me-2"></i>
              <span class="text-muted">
                <strong>FreelyShared</strong> - Share Freely. Love Generously.
              </span>
            </div>
          </div>
          <div class="col-md-6 text-md-end mt-2 mt-md-0">
            <small class="text-muted">
              Inspired by Acts 4:32 -
              <em>"They shared everything they had"</em>
            </small>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
