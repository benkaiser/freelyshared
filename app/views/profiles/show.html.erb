<% content_for :title, "My Profile - FreelyShared" %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <!-- Profile Header -->
      <div class="card shadow-sm mb-4">
        <div class="card-body p-4 text-center">
          <% if @member.photo.attached? %>
            <%= image_tag @member.photo_medium, class: "rounded-circle mb-3", width: 100, height: 100, style: "object-fit: cover;" %>
          <% else %>
            <img src="<%= @member.avatar_url(100) %>" class="rounded-circle mb-3" width="100" height="100" alt="">
          <% end %>
          <h3 class="mb-1"><%= @member.name %></h3>
          <p class="text-muted mb-1"><%= @member.email %></p>
          <% if @member.phone.present? %>
            <p class="text-muted mb-0"><i class="bi bi-phone me-1"></i><%= @member.phone %></p>
          <% end %>
          <div class="mt-3">
            <%= link_to edit_profile_path, class: "btn btn-primary btn-sm" do %>
              <i class="bi bi-pencil me-1"></i>Edit Profile
            <% end %>
          </div>
        </div>
      </div>

      <!-- Navigation Menu -->
      <div class="card shadow-sm mb-4">
        <div class="list-group list-group-flush">
          <%= link_to my_borrow_requests_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
            <span><i class="bi bi-arrow-left-right text-primary me-3"></i>Borrow Requests</span>
            <span>
              <% if pending_borrow_requests_count > 0 %>
                <span class="badge bg-danger rounded-pill me-1"><%= pending_borrow_requests_count %></span>
              <% end %>
              <i class="bi bi-chevron-right text-muted"></i>
            </span>
          <% end %>
          <%= link_to church_memberships_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
            <span><i class="bi bi-building text-primary me-3"></i>My Churches</span>
            <i class="bi bi-chevron-right text-muted"></i>
          <% end %>
          <%= link_to notification_settings_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
            <span><i class="bi bi-bell text-primary me-3"></i>Notifications</span>
            <i class="bi bi-chevron-right text-muted"></i>
          <% end %>
          <%= link_to members_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
            <span><i class="bi bi-people text-primary me-3"></i>Member Directory</span>
            <i class="bi bi-chevron-right text-muted"></i>
          <% end %>
        </div>
      </div>

      <% if current_church_member&.admin_of?(current_church) %>
        <div class="card shadow-sm mb-4">
          <div class="list-group list-group-flush">
            <%= link_to church_admin_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
              <span><i class="bi bi-shield-check text-primary me-3"></i>Church Admin</span>
              <span>
                <% pending_count = current_church.church_memberships.pending_approval.count %>
                <% if pending_count > 0 %>
                  <span class="badge bg-danger rounded-pill me-1"><%= pending_count %></span>
                <% end %>
                <i class="bi bi-chevron-right text-muted"></i>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="card shadow-sm mb-4">
        <div class="list-group list-group-flush">
          <%= link_to destroy_church_member_session_path, data: { turbo_method: :delete }, class: "list-group-item list-group-item-action text-danger" do %>
            <i class="bi bi-box-arrow-right me-3"></i>Sign out
          <% end %>
        </div>
      </div>

      <!-- Pending Borrow Requests -->
      <% if @incoming_pending.any? %>
        <div class="card border-danger shadow-sm mb-4">
          <div class="card-header bg-danger text-white">
            <h5 class="mb-0">
              <i class="bi bi-hand-index me-2"></i>Pending Borrow Requests
              <span class="badge bg-white text-danger ms-2"><%= @incoming_pending.count %></span>
            </h5>
          </div>
          <div class="card-body p-0">
            <div class="list-group list-group-flush">
              <% @incoming_pending.each do |request| %>
                <%= link_to item_path(request.item), class: "list-group-item list-group-item-action" do %>
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <strong><%= request.requester.name %></strong>
                      <span class="text-muted">wants to borrow</span>
                      <strong><%= request.item.title %></strong>
                      <br>
                      <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i><%= request.start_date.strftime("%b %d") %> - <%= request.end_date.strftime("%b %d, %Y") %>
                        <% if request.phone.present? %>
                          <span class="ms-2"><i class="bi bi-phone me-1"></i><%= request.phone %></span>
                        <% end %>
                      </small>
                    </div>
                    <span class="badge bg-warning text-dark">Pending</span>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>
