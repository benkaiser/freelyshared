<% content_for :title, "Notification Settings - FreelyShared" %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4"><i class="bi bi-bell text-primary me-2"></i>Notification Settings</h2>

      <div class="card mb-4">
        <div class="card-body p-4">
          <h5>Push Notifications</h5>
          <p class="text-muted">Get notified when something happens in your church community.</p>

          <div id="push-notification-setup" data-controller="push-notifications" data-push-notifications-vapid-key-value="<%= ENV['VAPID_PUBLIC_KEY'] %>">
            <button class="btn btn-primary" data-action="click->push-notifications#subscribe" data-push-notifications-target="subscribeBtn">
              <i class="bi bi-bell me-1"></i> Enable Push Notifications
            </button>
            <p class="text-success d-none" data-push-notifications-target="status">
              <i class="bi bi-check-circle me-1"></i> Push notifications are enabled for this device.
            </p>
          </div>
        </div>
      </div>

      <% if @subscriptions.any? %>
        <% @subscriptions.each do |sub| %>
          <div class="card mb-3">
            <div class="card-body p-4">
              <h5>Notification Preferences</h5>
              <%= form_with url: notification_settings_path, method: :patch, class: "row g-3" do |f| %>
                <%= hidden_field_tag :subscription_id, sub.id %>

                <div class="col-12">
                  <div class="form-check form-switch">
                    <%= check_box_tag :notify_new_needs, true, sub.notify_new_needs, class: "form-check-input", role: "switch" %>
                    <label class="form-check-label" for="notify_new_needs">
                      <strong>New needs posted</strong>
                      <br><small class="text-muted">Get notified when someone in your church posts a need</small>
                    </label>
                  </div>
                </div>

                <div class="col-12">
                  <div class="form-check form-switch">
                    <%= check_box_tag :notify_new_services, true, sub.notify_new_services, class: "form-check-input", role: "switch" %>
                    <label class="form-check-label" for="notify_new_services">
                      <strong>New services offered</strong>
                      <br><small class="text-muted">Get notified when someone offers a new service</small>
                    </label>
                  </div>
                </div>

                <div class="col-12">
                  <div class="form-check form-switch">
                    <%= check_box_tag :notify_new_items, true, sub.notify_new_items, class: "form-check-input", role: "switch" %>
                    <label class="form-check-label" for="notify_new_items">
                      <strong>New items listed</strong>
                      <br><small class="text-muted">Get notified when someone lists a new item to share</small>
                    </label>
                  </div>
                </div>

                <div class="col-12">
                  <div class="form-check form-switch">
                    <%= check_box_tag :notify_borrow_requests, true, sub.notify_borrow_requests, class: "form-check-input", role: "switch" %>
                    <label class="form-check-label" for="notify_borrow_requests">
                      <strong>Borrow requests</strong>
                      <br><small class="text-muted">Get notified when someone wants to borrow your item</small>
                    </label>
                  </div>
                </div>

                <div class="col-12">
                  <%= f.submit "Save Preferences", class: "btn btn-primary" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="alert alert-info">
          <i class="bi bi-info-circle me-1"></i>
          Enable push notifications above to configure your preferences.
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= link_to "Back to Profile", profile_path, class: "text-muted" %>
      </div>
    </div>
  </div>
</div>
