<% content_for :title, "Users - Superadmin" %>

<h2 class="mb-4"><i class="bi bi-people text-primary me-2"></i>Users</h2>

<!-- Search -->
<div class="mb-3">
  <%= form_tag superadmin_users_path, method: :get, class: "d-flex gap-2" do %>
    <input type="text" name="q" value="<%= params[:q] %>" class="form-control" placeholder="Search by name or email...">
    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
    <% if params[:q].present? %>
      <%= link_to "Clear", superadmin_users_path, class: "btn btn-outline-secondary" %>
    <% end %>
  <% end %>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Church</th>
          <th>Role</th>
          <th>Status</th>
          <th>Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="<%= 'table-danger' if user.suspended? %>">
            <td>
              <strong><%= link_to user.name, superadmin_user_path(user), class: "text-decoration-none" %></strong>
            </td>
            <td><small><%= user.email %></small></td>
            <td><small><%= link_to user.church.name, superadmin_church_path(user.church), class: "text-decoration-none" %></small></td>
            <td>
              <% if user.superadmin? %><span class="badge bg-dark">Superadmin</span><% end %>
              <% if user.admin? %><span class="badge bg-primary">Admin</span><% end %>
              <% unless user.admin? || user.superadmin? %><span class="badge bg-light text-dark">Member</span><% end %>
            </td>
            <td>
              <% if user.suspended? %>
                <span class="badge bg-danger">Suspended</span>
              <% elsif user.pending_approval? %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% else %>
                <span class="badge bg-success">Active</span>
              <% end %>
            </td>
            <td><small class="text-muted"><%= user.created_at.strftime("%b %d, %Y") %></small></td>
            <td>
              <%= link_to superadmin_user_path(user), class: "btn btn-sm btn-outline-primary" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
